server:
  port: 9090
  agentKey: "change-me-to-a-random-string"    # IMPORTANT: openssl rand -hex 24

services:
  # ─── Safe test service (start here!) ────────────────────
  # No signup needed. httpbin.org echoes your request back,
  # so you can verify ClawGuard injects the token correctly.
  httpbin:
    upstream: https://httpbin.org
    auth:
      type: bearer
      token: "test-secret-token-12345"   # fake token — httpbin echoes it back
    policy:
      default: require_approval

  # ─── GitHub (the real reason you need ClawGuard) ────────
  # Imagine a prompt injection tries: DELETE /repos/you/important-repo
  # Without ClawGuard: repo deleted. With ClawGuard: you tap Deny.
  #
  # Token can be a plain string or a secret reference:
  #   "ghp_your-github-token"                  -> static value
  #   "vault:secret/data/github#token"         -> HashiCorp Vault KV v2
  #   "vault:secret/github#token"              -> HashiCorp Vault KV v1
  github:
    upstream: https://api.github.com
    auth:
      type: bearer
      token: "ghp_your-github-token"
    policy:
      default: require_approval
      rules:
        - match: { method: GET }
          action: auto_approve              # reads pass through
        - match: { method: POST }
          action: require_approval          # writes need your OK
        - match: { method: DELETE }
          action: require_approval          # deletes DEFINITELY need your OK

  # ─── OpenAI (with host-based routing for forwarder) ─────
  openai:
    upstream: https://api.openai.com
    hostnames:                              # optional: for /etc/hosts or forwarder mode
      - api.openai.com
    auth:
      type: bearer
      token: "sk-your-openai-key-here"
    policy:
      default: require_approval
      rules:
        - match: { method: GET }
          action: auto_approve
        - match: { method: POST }
          action: require_approval

  # ─── OAuth2 service (e.g. Stripe) ──────────────────────
  # For APIs that use OAuth2 client_credentials flow.
  # The script sends dummy client_id/client_secret to the /token endpoint,
  # ClawGuard replaces them with the real ones before forwarding.
  # stripe:
  #   upstream: https://api.stripe.com
  #   auth:
  #     type: oauth2_client_credentials
  #     token: "unused"
  #     tokenPath: /oauth/token                # where the script POSTs for tokens
  #     clientId: "ca_your-client-id"
  #     clientSecret: "sk_live_your-client-secret"
  #   policy:
  #     default: require_approval
  #     rules:
  #       - match: { method: GET }
  #         action: auto_approve
  #       - match: { method: POST, path: /oauth/token }
  #         action: auto_approve               # let token exchange pass through

  # ─── Body JSON injection (e.g. Bluesky/AT Protocol) ─────
  # For APIs where credentials go in the JSON POST body, not headers.
  # ClawGuard injects/overwrites the configured fields in any JSON body.
  # bluesky:
  #   upstream: https://bsky.social
  #   auth:
  #     type: body_json
  #     token: "unused"
  #     fields:
  #       password: "your-bluesky-app-password"
  #   policy:
  #     default: require_approval
  #     rules:
  #       - match: { method: GET }
  #         action: auto_approve

  # ─── Auth Plugin (custom auth logic) ───────────────────
  # For APIs that need custom auth flows (token refresh, HMAC signing, etc.)
  # Plugins can modify headers, body, and even override the upstream URL.
  # Built-in: 'echo' (logs and passes through, for testing)
  # Custom: point to a .js file that exports createPlugin()
  # echo-test:
  #   upstream: https://httpbin.org
  #   auth:
  #     type: plugin
  #     token: "unused"
  #     pluginPath: echo                          # built-in plugin name
  #     pluginConfig:                             # arbitrary config passed to plugin
  #       injectHeader: x-custom-auth
  #       injectValue: "my-secret-value"
  #   policy:
  #     default: auto_approve
  #
  # custom-service:
  #   upstream: https://api.example.com
  #   auth:
  #     type: plugin
  #     token: "unused"
  #     pluginPath: ./my-plugins/custom-auth.js   # path to custom plugin module
  #     pluginConfig:
  #       apiKey: "your-api-key"
  #       refreshUrl: "https://auth.example.com/token"
  #   policy:
  #     default: require_approval

  # ─── AWS SigV4 (e.g. CloudTrail LookupEvents) ───────────
  # Signs requests with AWS Signature Version 4. Keep these IAM keys read-only.
  # aws-cloudtrail:
  #   upstream: https://cloudtrail.eu-west-1.amazonaws.com
  #   hostnames:
  #     - cloudtrail.eu-west-1.amazonaws.com
  #   auth:
  #     type: plugin
  #     token: "unused"
  #     pluginPath: aws-sigv4
  #     pluginConfig:
  #       accessKeyId: "AKIA..."
  #       secretAccessKey: "..."              # or vault:secret/data/aws-cloudtrail#secretAccessKey
  #       # sessionToken: "..."               # optional for base temporary credentials
  #       region: eu-west-1
  #       service: cloudtrail
  #       # Optional: assume a read-only role in a target AWS account before signing CloudTrail calls.
  #       # Configure one ClawGuard service per target role/account when you need multi-account access.
  #       # assumeRole:
  #       #   roleArn: "arn:aws:iam::123456789012:role/LogotelSecurityReadOnly"
  #       #   sessionName: "clawguard-cyberpolpo"
  #       #   # externalId: "..."              # optional, recommended for third-party/cross-account trust
  #       #   stsRegion: eu-west-1
  #       #   durationSeconds: 3600
  #   policy:
  #     default: require_approval
  #     rules:
  #       - match: { method: POST }
  #         action: auto_approve

  # ─── OAuth2 Authorization Code (e.g. Microsoft Graph) ──
  # For APIs using OAuth2 Authorization Code Flow with PKCE.
  # Tokens are stored in data/plugins/oauth2-authcode/tokens.json
  # Run `clawguard auth msgraph` to complete the initial authorization.
  # msgraph:
  #   upstream: https://graph.microsoft.com
  #   auth:
  #     type: plugin
  #     token: "unused"
  #     pluginPath: oauth2-authcode
  #     pluginConfig:
  #       authorizeUrl: "https://login.microsoftonline.com/common/oauth2/v2.0/authorize"
  #       tokenUrl: "https://login.microsoftonline.com/common/oauth2/v2.0/token"
  #       clientId: "your-app-client-id"
  #       # clientSecret: "your-client-secret"   # omit for public clients with PKCE
  #       redirectUri: "http://localhost:9999/callback"
  #       scopes:
  #         - openid
  #         - profile
  #         - User.Read
  #         - Mail.Read
  #       usePkce: true
  #   policy:
  #     default: require_approval
  #     rules:
  #       - match: { method: GET }
  #         action: auto_approve

  # ─── Anthropic (Claude API) ─────────────────────────────
  anthropic:
    upstream: https://api.anthropic.com
    auth:
      type: header
      headerName: x-api-key
      token: "sk-ant-your-api-key"
    policy:
      default: require_approval
      rules:
        - match: { method: POST, path: "/v1/messages" }
          action: require_approval           # API calls always need approval

  # ─── Slack ──────────────────────────────────────────────
  slack:
    upstream: https://slack.com/api
    hostnames:
      - slack.com
    auth:
      type: bearer
      token: "xoxb-your-slack-token"
    policy:
      default: require_approval

notifications:
  telegram:
    botToken: "${TELEGRAM_BOT_TOKEN}"
    chatId: "your-telegram-chat-id"
    pairing:
      enabled: true
      secret: "change-me-to-a-random-pairing-secret"  # IMPORTANT: openssl rand -hex 16

  # ─── Outbound webhook (fire-and-forget side notification) ──
  # Posts a JSON payload to a URL of your choice every time an approval
  # is requested, and (optionally) when it's resolved. Useful to plug
  # ClawGuard into any external alerting or automation system that can
  # ingest a webhook. This channel does NOT participate in the approval
  # decision — Telegram is still the decider.
  #
  # Payload (approval_required):
  #   { "event": "approval_required", "requestId": "...",
  #     "service": "github", "method": "DELETE", "path": "/repos/x/y",
  #     "agentIp": "1.2.3.4", "timestamp": 1700000000000,
  #     "dashboardUrl": "..." }
  #
  # Payload (approval_resolved, when cancelOnResolve is true):
  #   { "event": "approval_resolved", "requestId": "...",
  #     "approved": true, "approvedBy": "alice", "timestamp": ... }
  #
  # webhook:
  #   enabled: true
  #   url: "https://your-system.example.com/hook/abc123"
  #   method: POST                                    # POST (default) or PUT
  #   timeoutMs: 5000                                 # default 5s
  #   cancelOnResolve: true                           # also notify when approval is resolved (default true)
  #   dashboardUrl: "https://clawguard.example.com/__admin/"   # optional, included in payload
  #   headers:                                        # optional custom headers
  #     X-My-Token: "${MY_HOOK_TOKEN}"

security:
  allowedUpstreams:
    - httpbin.org
    - api.github.com
    - api.openai.com
    - api.anthropic.com
    - api.stripe.com
    - graph.microsoft.com
    - slack.com
    # - cloudtrail.eu-west-1.amazonaws.com   # needed for aws-cloudtrail example above
  blockPrivateIPs: true
  followRedirects: false
  maxPayloadLogSize: 10240

admin:
  enabled: true
  pin: "change-me"                          # IMPORTANT: quote it! YAML parses numbers as integers
  allowedIPs:
    - "127.0.0.1"
    - "::1"
    - "172.16.0.0/12"                       # Docker networks (172.16-31.x.x)
    # - "192.168.1.0/24"                    # uncomment to allow entire LAN
    # - "172.17.0.1"                        # Docker: host IP on default bridge network
    # - "172.16.0.0/12"                     # Docker: allow all Docker networks (172.16-31.x.x)

  # ─── Admin HTTPS listener ─────────────────────────────────
  # Required if you want to use Web Push notifications from a browser
  # accessing the dashboard from a non-localhost address. Service Workers
  # and the Push API are gated to "secure contexts" (https or http://localhost),
  # so a plain http://LAN-IP:9090 dashboard cannot enable Web Push.
  #
  # When enabled, a second listener serves the admin UI only over TLS.
  # The leaf cert is signed by the same CA in `data/ca/` that ClawGuard
  # uses for MITM mode — trust this CA once in your Keychain (macOS) or
  # browser to avoid TLS warnings.
  #
  # https:
  #   enabled: true
  #   port: 9443
  #   hostnames:                       # SAN entries on the leaf cert
  #     - 192.168.1.50                # add the LAN IP/hostname you connect from
  #     - clawguard.local
  # localhost and 127.0.0.1 are always added automatically.

audit:
  type: sqlite
  path: ./data/clawguard.db    # use ./data/ for Docker volume persistence
  logPayload: false

# ─── HTTPS_PROXY mode (Mode C) ──────────────────────────────
# When enabled, ClawGuard also handles CONNECT requests on the same port.
# Your scripts don't need ANY changes — just set an env var:
#   export HTTPS_PROXY=http://YOUR_AGENT_KEY:x@clawguard-host:9090
#   export NODE_EXTRA_CA_CERTS=/path/to/data/ca/ca.crt
# ClawGuard intercepts TLS, applies approval policies, injects real tokens.
proxy:
  enabled: false
  caDir: ./data/ca              # CA cert/key stored here (auto-generated on first run)
  discovery: false              # enable discovery handling for unknown hosts
  discoveryPolicy: block        # block (default) | silent_allow (explicit opt-in)

# ─── Secret providers ────────────────────────────────────────
# External secret backends for resolving token references.
# Use "vault:path#field" syntax in service auth.token values.
#
# Environment variable overrides (useful for CI/CD and testing):
#   VAULT_ADDR          -> secrets.vault.address
#   VAULT_TOKEN         -> secrets.vault.auth.token (also forces method: token)
#   VAULT_NAMESPACE     -> secrets.vault.namespace
#   VAULT_SKIP_VERIFY   -> secrets.vault.tlsSkipVerify (set to "true")
#   VAULT_K8S_ROLE      -> secrets.vault.auth.role
#   VAULT_K8S_MOUNT_PATH -> secrets.vault.auth.mountPath
#
# secrets:
#   vault:
#     address: https://vault.example.com
#     # namespace: admin/team1               # Vault Enterprise namespace (optional)
#     # tlsSkipVerify: false                 # skip TLS verification (default: false)
#     # cacheTTL: 300                        # seconds to cache secrets (default: 300)
#     auth:
#       method: token                        # "token" or "kubernetes"
#       token: "${VAULT_TOKEN}"              # for method: token
#       # For Kubernetes auth (in-pod):
#       # method: kubernetes
#       # role: clawguard                    # Vault role bound to the SA
#       # mountPath: auth/kubernetes          # default
